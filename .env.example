# clientctl — environment configuration
#
# Copy this file to .env (which is gitignored) and fill in your values:
#   cp .env.example .env
#
# Variables are loaded by `python-dotenv` at server start; see config.py.


# ──────────────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────────────

# Setup password — required to register a new passkey via the UI.
# Treat it like a long-lived API key: 30+ random chars, never commit.
# Without this set, passkey registration returns "Server setup incomplete"
# and only code login works.
#
# Generate a fresh one:
#   python -c "import secrets; print(secrets.token_urlsafe(27))"
#
PASSKEY_REGISTRATION_PASSWORD=

# WebAuthn relying-party ID. Must equal the hostname of the URL you
# access clientctl from — the browser refuses passkeys otherwise.
#
#   Cloudflare tunnel:    your public hostname (e.g. clientctl.example.com)
#   Reverse proxy + TLS:  the proxied hostname (matching the certificate)
#   Plain HTTP on LAN:    WebAuthn does NOT work over insecure origins,
#                         use code login only
#
RP_ID=clientctl.example.com


# ──────────────────────────────────────────────────────────────────────
# Optional
# ──────────────────────────────────────────────────────────────────────

# Display name shown in the passkey UI ("Sign in as ___").
# Default: the current $USER (via getpass.getuser()).
#CLIENTCTL_USER_NAME=

# HTTP port the Flask server binds to. Default 8090.
#CLIENTCTL_PORT=8090

# Deployment mode. One of:
#   dev     → bind 127.0.0.1 only, no tunnel (development on the host)
#   lan     → bind 0.0.0.0  (LAN-reachable)            ←  default
#   tunnel  → bind 127.0.0.1, start cloudflared        (HTTPS via tunnel)
# CLIENTCTL_TUNNEL=1 is a backward-compatible alias for tunnel mode.
#CLIENTCTL_MODE=lan
#CLIENTCTL_TUNNEL=

# Maximum number of passkeys that may be registered. Default 2.
# Increase if you want to enroll more devices (one per phone, tablet,
# laptop, hardware key, etc.).
#CLIENTCTL_MAX_PASSKEYS=2

# Default session lifetime in days (after a successful code login).
# Default 7. Reduce for stricter re-auth, raise if you trust the device.
#CLIENTCTL_SESSION_TTL_DAYS=7

# "Remember me" lifetime — used when the user ticks the checkbox on the
# login screen. Default 14 days. Should be ≥ CLIENTCTL_SESSION_TTL_DAYS.
#CLIENTCTL_SESSION_REMEMBER_DAYS=14

# Log verbosity. One of: DEBUG / INFO / WARNING / ERROR. Default INFO.
#CLIENTCTL_LOG_LEVEL=INFO

# Mark the session cookie as Secure (HTTPS-only). Enable ONLY when
# clientctl is reached exclusively via HTTPS (Cloudflare tunnel, reverse
# proxy with TLS, …). On plain HTTP the browser refuses Secure cookies
# and login breaks. Default off.
#CLIENTCTL_COOKIE_SECURE=true

# Feature opt-out — comma-separated capability keys to hide from the UI
# regardless of detection. Useful when the system *can* do something but
# you don't want the control surfaced. Recognised keys:
#   audio, battery, power_profiles, gpu, dbus_monitor, cachy,
#   kde_brightness, ddc, brightness  (alias: hides both kde_brightness + ddc)
# Example — hide GPU stats and per-app audio sliders:
#   CLIENTCTL_DISABLE_FEATURES=gpu,audio
#CLIENTCTL_DISABLE_FEATURES=

# Maximum themes loaded from themes.yml. Default 8 keeps the picker
# scannable. Themes are kept in file order, so the first N win when the
# file has more. The loader logs a warning naming the dropped entries.
# Set to 0 to disable the cap entirely (load everything in themes.yml).
#CLIENTCTL_THEMES_LIMIT=8
